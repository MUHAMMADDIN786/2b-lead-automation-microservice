# Server Configuration
PORT=3000
NODE_ENV=development

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# CRM Config (HubSpot / Google Sheets / Custom CRM)
# If using CRM webhooks or API endpoints
CRM_ENDPOINT_URL=https://api.hubapi.com/crm/v3/objects/contacts
CRM_ACCESS_TOKEN=your_crm_access_token_here

# Security
WEBHOOK_SECRET=your_shared_webhook_secret_here
